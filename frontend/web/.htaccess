# ========================================================
# DC NEET Counselling - Performance & Security Headers
# For Apache / Hostinger
# ========================================================

# ─── Security Headers ──────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self)"
    
    # HSTS - force HTTPS for 1 year
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ─── Force HTTPS ───────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ─── Brotli Compression (Optimal) ─────────────────────
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml font/woff font/woff2
</IfModule>

# ─── Gzip Compression (Fallback) ──────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml font/woff font/woff2
    
    # Do not compress things that are already compressed
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|mp4|zip)$ no-gzip dont-vary
</IfModule>

# ─── Browser Caching & Cache-Control ──────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images & Media - Cache for 1 Year (Immutable)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS & JS - Cache for 1 Year (Since versioning ?v= is used)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Fonts - Cache for 1 Year
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # HTML - No Cache / Must Revalidate
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Add Cache-Control headers for static assets
    <FilesMatch "\.(js|css|webp|png|jpg|jpeg|gif|svg|woff2?|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Prevent caching of dynamic/HTML content
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>

# ─── Prevent Directory Listing & Protect Files ────────
Options -Indexes

<FilesMatch "\.(env|git|gitignore|md|sql|log|txt|json|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to hidden files/directories
<IfModule mod_rewrite.c>
    RewriteRule "(^|/)\.(?!well-known)" - [F]

    # Dynamic Sitemap Routing
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Universal SPA Routing: Redirect all non-file/folder requests to index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>
